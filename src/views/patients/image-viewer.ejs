<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="container page-space">
  <%- include('../partials/flash') %>

  <section class="card viewer-header-card">
    <div class="section-title">
      <div>
        <p class="eyebrow">Viewer</p>
        <h1><%= image.original_name %></h1>
        <p class="muted">
          <strong>Patient:</strong> <%= patient.full_name %> ·
          <strong>Patient ID:</strong> <%= patient.patient_id %>
        </p>
        <p class="muted small">
          <strong>Type:</strong> <%= viewerKindLabel(image.viewer_kind) %>
          <% if (image.mime_type) { %>
            · <strong>MIME:</strong> <%= image.mime_type %>
          <% } %>
        </p>
      </div>
      <div class="hero-actions">
        <a href="/patients/<%= patient.id %>" class="btn btn-outline">Back to Patient</a>
        <a href="<%= image.image_path %>" class="btn btn-primary" target="_blank" rel="noreferrer">Open Raw File</a>
      </div>
    </div>
  </section>

  <% if (image.viewer_kind === 'image') { %>
    <section class="card">
      <div class="viewer-image-wrap">
        <img src="<%= image.image_path %>" alt="<%= image.original_name %>" class="viewer-image" />
      </div>
    </section>
  <% } else if (image.viewer_kind === 'dicom') { %>
    <section class="card viewer-card">
      <div class="viewer-toolbar">
        <div>
          <strong>Raw DICOM viewer</strong>
          <p class="muted small">This page keeps the original <code>.dcm</code> file untouched and uses Orthanc/OHIF when available.</p>
        </div>
      </div>

      <% if (orthancViewerUrl) { %>
        <div class="integration-note ready">
          <strong>Orthanc/OHIF ready.</strong>
          <span>This DICOM is synced and should open in the embedded medical viewer below. If your browser blocks the embed, use the button to open OHIF in a new tab.</span>
        </div>
        <div class="hero-actions viewer-link-row">
          <a href="<%= orthancViewerUrl %>" class="btn btn-primary" target="_blank" rel="noreferrer">Open in OHIF</a>
          <a href="<%= image.image_path %>" class="btn btn-outline" target="_blank" rel="noreferrer">Download Raw DICOM</a>
        </div>
        <div class="ohif-frame-wrap">
          <iframe src="<%= orthancViewerUrl %>" title="OHIF medical viewer" class="ohif-frame"></iframe>
        </div>
      <% } else { %>
        <div class="integration-note warning">
          <strong>Orthanc/OHIF is not ready for this file.</strong>
          <span>
            <% if (image.orthanc_sync_error) { %>
              Sync error: <%= image.orthanc_sync_error %>
            <% } else if (orthancEnabled) { %>
              This file is raw DICOM, but it has not been linked to an Orthanc study yet.
            <% } else { %>
              Start the free Orthanc/OHIF stack to view raw DICOM reliably in the browser.
            <% } %>
          </span>
        </div>
        <section class="card empty-state viewer-fallback-card">
          <h2>Raw DICOM stored successfully</h2>
          <p class="muted">
            The app preserved the original <code>.dcm</code> file. Open or download the raw file now, or enable Orthanc/OHIF for a stronger browser viewer.
          </p>
          <div class="hero-actions viewer-link-row center-row">
            <a href="<%= image.image_path %>" class="btn btn-primary" target="_blank" rel="noreferrer">Open Raw File</a>
          </div>
        </section>
      <% } %>
    </section>
  <% } else { %>
    <section class="card empty-state">
      <h2>This file is stored, but not rendered inline.</h2>
      <p class="muted">
        DICOMDIR folders and archives usually need the referenced files together. For direct web viewing, upload a single DICOM (.dcm) or JPG from CS Imaging.
      </p>
      <a href="<%= image.image_path %>" class="btn btn-primary" target="_blank" rel="noreferrer">Download File</a>
    </section>
  <% } %>
</main>
<%- include('../partials/footer') %>
